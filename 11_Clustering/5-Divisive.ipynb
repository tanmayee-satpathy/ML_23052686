   "source": [
    "from sklearn.cluster import AgglomerativeClustering\n",
    "import numpy as np\n",
    "\n",
    "X = np.array([\n",
    "    [1,2], [1,4], [1,0],\n",
    "    [10,2], [10,4], [10,0]\n",
    "])\n",
    "\n",
    "model = AgglomerativeClustering(n_clusters=2)\n",
    "\n",
    "labels = model.fit_predict(X)\n",
    "\n",
    "print(labels)"
   ]
  },
